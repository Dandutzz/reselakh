# Postgres connection string. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Local dev example (Docker):
#   docker run -d --name reselakh-pg -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=reselakh -p 5432:5432 postgres:16-alpine
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reselakh?schema=public"

# Secret used to sign auth JWTs. REQUIRED — the app will refuse to start if
# this is not set. Use a long random string (e.g. `openssl rand -base64 48`).
NEXTAUTH_SECRET="change-this-to-a-random-secret-of-at-least-32-bytes"

# Public URL used by the SEO/OpenGraph metadata. Optional in dev.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
